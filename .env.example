# Docker Compose Environment Variables Example
# Copy this file to .env and fill in your actual values before running docker compose

# The port your backend Express server will run on (inside the container)
PORT=5000

# Connection string for MongoDB (using Docker service name 'mongo')
MONGODB_URI=mongodb://mongo:27017/game-recommendations

# Connection string for Redis (using Docker service name 'redis')
REDIS_URL=redis://redis:6379

# Your secret RAWG API Key
RAWG_API_KEY=your_rawg_api_key_here
